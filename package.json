{
  "name": "sugarmagic",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "pnpm --dir apps/studio build && pnpm --dir targets/web build && pnpm typecheck",
    "dev:studio": "pnpm --dir apps/studio dev",
    "dev:web": "pnpm --dir targets/web dev",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . && pnpm lint:boundaries && pnpm lint:shell-tokens && pnpm lint:filenames",
    "lint:boundaries": "node tooling/check-package-boundaries.mjs",
    "lint:filenames": "node tooling/check-filename-conventions.mjs",
    "lint:shell-tokens": "node tooling/check-shell-tokens.mjs",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "ajv": "^8.18.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "xlsx": "^0.18.5"
  }
}
