{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sugarmagic.dev/sugarlang/schemas/cefrlex.schema.json",
  "title": "Sugarlang CEFR Lexicon",
  "description": "Plugin-shipped lexical atlas data keyed by lemma id.",
  "type": "object",
  "additionalProperties": false,
  "required": ["lang", "atlasVersion", "lemmas"],
  "properties": {
    "lang": {
      "type": "string",
      "minLength": 2
    },
    "atlasVersion": {
      "type": "string",
      "minLength": 1
    },
    "lemmas": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/atlasLemmaEntry"
      }
    }
  },
  "$defs": {
    "cefrBand": {
      "type": "string",
      "enum": ["A1", "A2", "B1", "B2", "C1", "C2"]
    },
    "atlasLemmaEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lemmaId",
        "lang",
        "cefrPriorBand",
        "frequencyRank",
        "partsOfSpeech",
        "cefrPriorSource"
      ],
      "properties": {
        "lemmaId": {
          "type": "string",
          "minLength": 1
        },
        "lang": {
          "type": "string",
          "minLength": 2
        },
        "cefrPriorBand": {
          "$ref": "#/$defs/cefrBand"
        },
        "frequencyRank": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "partsOfSpeech": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "gloss": {
          "type": "string",
          "minLength": 1
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cefrPriorSource": {
          "type": "string",
          "enum": [
            "cefrlex",
            "frequency-derived",
            "claude-classified",
            "human-override",
            "kelly"
          ]
        }
      }
    }
  }
}
