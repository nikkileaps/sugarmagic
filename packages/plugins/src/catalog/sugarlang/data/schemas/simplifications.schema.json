{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sugarmagic.dev/sugarlang/schemas/simplifications.schema.json",
  "title": "Sugarlang Simplifications Dictionary",
  "description": "Deterministic lower-band substitutions or gloss fallbacks keyed by higher-band lemma id.",
  "type": "object",
  "additionalProperties": false,
  "required": ["lang", "entries"],
  "properties": {
    "lang": {
      "type": "string",
      "minLength": 2
    },
    "entries": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "#/$defs/simplificationEntry"
        }
      }
    }
  },
  "$defs": {
    "simplificationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["lemma-substitution", "gloss-fallback"]
        },
        "lemmaId": {
          "type": "string",
          "minLength": 1
        },
        "gloss": {
          "type": "string",
          "minLength": 1
        },
        "contextTags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "lemma-substitution"
              }
            }
          },
          "then": {
            "required": ["lemmaId"]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "gloss-fallback"
              }
            }
          },
          "then": {
            "required": ["gloss"]
          }
        }
      ]
    }
  }
}
