{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sugarmagic.dev/schemas/vfx-definition.schema.json",
  "title": "Sugarmagic VFXDefinition",
  "type": "object",
  "required": [
    "definitionId",
    "definitionKind",
    "displayName",
    "description",
    "emissionRatePerSecond",
    "maxParticles",
    "lifetimeMinSeconds",
    "lifetimeMaxSeconds",
    "colorStart",
    "colorEnd",
    "sizeStart",
    "sizeEnd",
    "initialVelocity",
    "velocityRandomness",
    "spreadConeDegrees",
    "gravity",
    "blendMode",
    "shape"
  ],
  "properties": {
    "definitionId": { "type": "string", "minLength": 1 },
    "definitionKind": { "const": "vfx" },
    "displayName": { "type": "string" },
    "description": { "type": "string" },
    "metadata": {
      "type": "object",
      "properties": {
        "builtIn": { "type": "boolean" },
        "builtInKey": { "type": "string" }
      },
      "additionalProperties": false
    },
    "emissionRatePerSecond": { "type": "number", "minimum": 0 },
    "maxParticles": { "type": "integer", "minimum": 1 },
    "lifetimeMinSeconds": { "type": "number", "exclusiveMinimum": 0 },
    "lifetimeMaxSeconds": { "type": "number", "exclusiveMinimum": 0 },
    "colorStart": { "$ref": "#/$defs/color" },
    "colorEnd": { "$ref": "#/$defs/color" },
    "sizeStart": { "type": "number", "minimum": 0 },
    "sizeEnd": { "type": "number", "minimum": 0 },
    "initialVelocity": { "$ref": "#/$defs/vector3" },
    "velocityRandomness": { "type": "number", "minimum": 0, "maximum": 1 },
    "spreadConeDegrees": { "type": "number", "minimum": 0, "maximum": 360 },
    "gravity": { "$ref": "#/$defs/vector3" },
    "blendMode": { "enum": ["additive", "normal"] },
    "shape": { "enum": ["circle", "square"] }
  },
  "additionalProperties": false,
  "$defs": {
    "color": {
      "type": "object",
      "required": ["r", "g", "b", "a"],
      "properties": {
        "r": { "type": "number", "minimum": 0, "maximum": 1 },
        "g": { "type": "number", "minimum": 0, "maximum": 1 },
        "b": { "type": "number", "minimum": 0, "maximum": 1 },
        "a": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "vector3": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      },
      "additionalProperties": false
    }
  }
}
